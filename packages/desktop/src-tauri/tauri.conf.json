{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeOS",
  "version": "0.1.0",
  "identifier": "com.meos.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm -C ../.. run dev",
    "frontendDist": "../../web/dist",
    "beforeBuildCommand": "pnpm -C ../.. run build"
  },
  "app": {
    "windows": [
      {
        "title": "MeOS",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 620,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
