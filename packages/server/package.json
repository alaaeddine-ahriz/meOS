{
  "name": "@meos/server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "sh -c 'ulimit -n unlimited 2>/dev/null || true; exec tsx watch src/main.ts'",
    "start": "sh -c 'ulimit -n unlimited 2>/dev/null || true; exec node dist/main.js'",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@meos/contracts": "workspace:*",
    "@meos/core": "workspace:*",
    "@meos/wiki-mcp": "workspace:*",
    "croner": "^9.0.0",
    "fastify": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
