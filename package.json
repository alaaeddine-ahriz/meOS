{
  "name": "meos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @meos/core build && pnpm --parallel --filter @meos/core --filter @meos/server --filter @meos/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "desktop": "pnpm --filter @meos/desktop dev",
    "desktop:build": "pnpm --filter @meos/desktop bundle",
    "dev:container": "docker compose -f docker/docker-compose.dev.yml up"
  },
  "devDependencies": {
    "shadcn": "^4.11.0"
  }
}
