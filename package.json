{
  "name": "meos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @meos/core build && pnpm --parallel --filter @meos/core --filter @meos/server --filter @meos/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "desktop": "pnpm --filter @meos/desktop dev",
    "desktop:build": "pnpm --filter @meos/desktop bundle",
    "prepare": "simple-git-hooks"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs,json,css,scss,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.39.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.5.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.0",
    "shadcn": "^4.11.0",
    "simple-git-hooks": "^2.13.1",
    "typescript-eslint": "^8.49.0"
  }
}
