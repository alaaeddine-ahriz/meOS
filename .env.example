# meOS environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit a populated
# `.env` — it is git-ignored. These are the variables meOS reads at runtime
# (see packages/*/src). All are optional; meOS falls back to on-disk config
# and sensible defaults when a variable is unset.

# --- LLM provider selection ------------------------------------------------
# Which LLM backend the core uses. One of: anthropic | openai | google | local | stub
# (see packages/core/src/config.ts). Overrides the stored config when set.
MEOS_LLM_PROVIDER=anthropic

# --- LLM provider API keys -------------------------------------------------
# Cloud providers read their key from the matching env var if it is not stored
# in app config (see packages/server/src/routes/settings.ts). Treat these as
# secrets — do not commit real values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Google/Gemini accepts either name; the first non-empty one wins.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# --- Paths & caches --------------------------------------------------------
# Root directory for meOS data (SQLite db, indexes, attachments). Defaults to a
# per-OS application data dir when unset (packages/core/src/config.ts).
MEOS_DATA_DIR=

# Cache directory for downloaded embedding models
# (@huggingface/transformers, packages/core/src/embedding/embedder.ts).
MEOS_MODEL_CACHE=

# Directory the server serves the built web UI from. Defaults to the bundled
# web/dist (packages/server/src/server.ts).
MEOS_WEB_DIST=

# --- Process / runtime control ---------------------------------------------
# When "1", the server process exits if its parent process dies — used by the
# desktop shell to avoid orphaned servers (packages/server/src/main.ts).
MEOS_EXIT_WITH_PARENT=

# --- Build / packaging (CI only, not needed for normal runtime) ------------
# Node version baked into the bundled desktop runtime payload. Must match the
# CI runner's Node major (scripts/bundle-runtime.mjs).
MEOS_BUNDLE_NODE_VERSION=22.12.0
