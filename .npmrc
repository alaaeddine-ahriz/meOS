# Refuse to install on a Node version that doesn't satisfy `engines.node` (22.x).
# Native modules (better-sqlite3) are ABI-bound to the Node major; installing on
# the wrong one yields a server that crashes at boot with ERR_DLOPEN_FAILED and a
# dead app (ECONNREFUSED). Failing the install instead makes the mismatch obvious.
# CI and the desktop bundler already run Node 22 (.nvmrc); run `nvm use` locally.
engine-strict=true
